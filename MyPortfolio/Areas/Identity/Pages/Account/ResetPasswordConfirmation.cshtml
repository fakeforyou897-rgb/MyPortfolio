@page
@model ResetPasswordConfirmationModel
@{
  ViewData["Title"] = "Password Reset";
}

<section class="section" style="min-height:60vh;display:flex;align-items:center;">
  <div class="container" style="max-width:440px;width:100%;text-align:center;">
    <div style="font-size:3rem;margin-bottom:1rem;">✅</div>
    <h1 style="font-size:1.75rem;font-weight:800;color:var(--color-text);margin-bottom:0.75rem;">Password Reset</h1>
    <p style="color:var(--color-text-muted);margin-bottom:2rem;">
      Your password has been successfully reset. You can now sign in with your new password.
    </p>
    <a asp-page="./Login" class="btn btn-primary">Sign In</a>
  </div>
</section>
