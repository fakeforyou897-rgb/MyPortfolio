@page
@model RegisterModel
@{
  ViewData["Title"] = "Create Account";
}

<section class="section" style="min-height:70vh;display:flex;align-items:center;">
  <div class="container" style="max-width:440px;width:100%;">

    <div style="text-align:center;margin-bottom:2rem;">
      <h1 style="font-size:1.75rem;font-weight:800;color:var(--color-text);margin-bottom:0.4rem;">Create Account</h1>
      <p style="color:var(--color-text-muted);font-size:0.9rem;margin:0;">Fill in the details below to get started</p>
    </div>

    <div class="card" style="padding:2rem;">
      <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
        <div asp-validation-summary="ModelOnly" class="form-alert form-alert-error" style="margin-bottom:1.25rem;"></div>

        <div class="form-group">
          <label asp-for="Input.Email" class="form-label">Email Address</label>
          <input asp-for="Input.Email" type="email" class="form-control" placeholder="you@example.com"
                 autocomplete="username" aria-required="true" />
          <span asp-validation-for="Input.Email" class="field-validation-error"></span>
        </div>

        <div class="form-group">
          <label asp-for="Input.Password" class="form-label">Password</label>
          <input asp-for="Input.Password" type="password" class="form-control" placeholder="Create a strong password"
                 autocomplete="new-password" aria-required="true" />
          <span asp-validation-for="Input.Password" class="field-validation-error"></span>
        </div>

        <div class="form-group">
          <label asp-for="Input.ConfirmPassword" class="form-label">Confirm Password</label>
          <input asp-for="Input.ConfirmPassword" type="password" class="form-control" placeholder="Repeat your password"
                 autocomplete="new-password" aria-required="true" />
          <span asp-validation-for="Input.ConfirmPassword" class="field-validation-error"></span>
        </div>

        <button id="registerSubmit" type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:0.75rem;">
          Create Account
        </button>

        <div style="text-align:center;margin-top:1.25rem;font-size:0.85rem;color:var(--color-text-muted);">
          Already have an account?
          <a asp-page="./Login" style="color:var(--color-primary);font-weight:600;">Sign In</a>
        </div>
      </form>
    </div>

    @if ((Model.ExternalLogins?.Count ?? 0) > 0)
    {
      <div class="card" style="margin-top:1rem;padding:1.5rem;">
        <div style="text-align:center;font-size:0.8rem;color:var(--color-text-muted);margin-bottom:1rem;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;">Or register with</div>
        <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
          <div style="display:flex;flex-direction:column;gap:0.5rem;">
            @foreach (var provider in Model.ExternalLogins!)
            {
              <button type="submit" class="btn btn-secondary" name="provider" value="@provider.Name"
                      style="width:100%;justify-content:center;">
                @provider.DisplayName
              </button>
            }
          </div>
        </form>
      </div>
    }
  </div>
</section>

@section Scripts {
  <partial name="_ValidationScriptsPartial" />
}
