@page
@model ForgotPasswordModel
@{
  ViewData["Title"] = "Forgot Password";
}

<section class="section" style="min-height:60vh;display:flex;align-items:center;">
  <div class="container" style="max-width:440px;width:100%;">
    <div style="text-align:center;margin-bottom:2rem;">
      <div style="font-size:2.5rem;margin-bottom:0.75rem;">🔑</div>
      <h1 style="font-size:1.75rem;font-weight:800;color:var(--color-text);margin-bottom:0.4rem;">Forgot Password?</h1>
      <p style="color:var(--color-text-muted);font-size:0.9rem;margin:0;">Enter your email and we'll send you a reset link</p>
    </div>
    <div class="card" style="padding:2rem;">
      <form method="post">
        <div asp-validation-summary="ModelOnly" class="form-alert form-alert-error" style="margin-bottom:1.25rem;"></div>
        <div class="form-group">
          <label asp-for="Input.Email" class="form-label">Email Address</label>
          <input asp-for="Input.Email" type="email" class="form-control" placeholder="you@example.com" autocomplete="username" aria-required="true" />
          <span asp-validation-for="Input.Email" class="field-validation-error"></span>
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:0.75rem;">Send Reset Link</button>
        <div style="text-align:center;margin-top:1rem;font-size:0.85rem;">
          <a asp-page="./Login" style="color:var(--color-primary);">← Back to Sign In</a>
        </div>
      </form>
    </div>
  </div>
</section>

@section Scripts {
  <partial name="_ValidationScriptsPartial" />
}
