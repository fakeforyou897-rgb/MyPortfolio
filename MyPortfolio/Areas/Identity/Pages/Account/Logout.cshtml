@page
@model LogoutModel
@{
  ViewData["Title"] = "Signed Out";
}

<section class="section" style="min-height:60vh;display:flex;align-items:center;">
  <div class="container" style="max-width:440px;width:100%;text-align:center;">
    @if (User.Identity?.IsAuthenticated ?? false)
    {
      <div style="font-size:3rem;margin-bottom:1rem;">👋</div>
      <h1 style="font-size:1.75rem;font-weight:800;color:var(--color-text);margin-bottom:0.75rem;">Sign Out</h1>
      <p style="color:var(--color-text-muted);margin-bottom:2rem;">Click below to confirm signing out.</p>
      <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
        <button type="submit" class="btn btn-danger">Sign Out</button>
      </form>
    }
    else
    {
      <div style="font-size:3rem;margin-bottom:1rem;">✅</div>
      <h1 style="font-size:1.75rem;font-weight:800;color:var(--color-text);margin-bottom:0.75rem;">You're signed out</h1>
      <p style="color:var(--color-text-muted);margin-bottom:2rem;">You have been successfully signed out of your account.</p>
      <a href="/" class="btn btn-primary">Go Home</a>
    }
  </div>
</section>
