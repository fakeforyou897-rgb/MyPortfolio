@page
@model AccessDeniedModel
@{
  ViewData["Title"] = "Access Denied";
}

<section class="section" style="min-height:60vh;display:flex;align-items:center;">
  <div class="container" style="max-width:520px;width:100%;text-align:center;">
    <div style="font-size:4rem;margin-bottom:1rem;">🔒</div>
    <h1 style="font-size:1.75rem;font-weight:800;color:var(--color-text);margin-bottom:0.75rem;">Access Denied</h1>
    <p style="color:var(--color-text-muted);margin-bottom:2rem;">
      You don't have permission to access this page. Please contact the administrator if you believe this is a mistake.
    </p>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      <a href="/" class="btn btn-primary">Go Home</a>
      <button onclick="history.back()" class="btn btn-ghost">← Go Back</button>
    </div>
  </div>
</section>
