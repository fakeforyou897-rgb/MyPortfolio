@{
  Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}
@model MyPortfolio.Models.ViewModels.Admin.DashboardViewModel

<div style="margin-bottom:1.75rem;">
  <h1 style="font-size:1.5rem;font-weight:800;color:var(--color-text);margin-bottom:0.25rem;font-family:'Iceberg','Inter',sans-serif;">Dashboard</h1>
  <p style="color:var(--color-text-muted);font-size:0.875rem;margin:0;">Welcome back! Here's what's happening.</p>
</div>

<!-- Stat Cards — no border-left -->
<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1.25rem;margin-bottom:2rem;">

  <div class="card" style="padding:1.25rem;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem;">
      <div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-text-muted);">Projects</div>
      <div style="width:34px;height:34px;border-radius:var(--radius-md);background:var(--color-primary-soft);display:flex;align-items:center;justify-content:center;color:var(--color-primary);">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
      </div>
    </div>
    <div style="font-size:2rem;font-weight:800;color:var(--color-primary);line-height:1;font-family:'Iceberg','Inter',sans-serif;">@ViewBag.ProjectCount</div>
    <a href="/Admin/Projects/Create" style="display:inline-flex;align-items:center;gap:0.25rem;margin-top:0.75rem;font-size:0.78rem;color:var(--color-primary);font-weight:600;">
      <svg width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
      Add Project
    </a>
  </div>

  <div class="card" style="padding:1.25rem;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem;">
      <div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-text-muted);">Blog Posts</div>
      <div style="width:34px;height:34px;border-radius:var(--radius-md);background:#d1fae5;display:flex;align-items:center;justify-content:center;color:#059669;">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      </div>
    </div>
    <div style="font-size:2rem;font-weight:800;color:#10b981;line-height:1;font-family:'Iceberg','Inter',sans-serif;">@ViewBag.BlogCount</div>
    <a href="/Admin/BlogPosts/Create" style="display:inline-flex;align-items:center;gap:0.25rem;margin-top:0.75rem;font-size:0.78rem;color:#10b981;font-weight:600;">
      <svg width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
      Add Post
    </a>
  </div>

  <div class="card" style="padding:1.25rem;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem;">
      <div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-text-muted);">Messages</div>
      <div style="width:34px;height:34px;border-radius:var(--radius-md);background:#fef3c7;display:flex;align-items:center;justify-content:center;color:#d97706;">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
      </div>
    </div>
    <div style="font-size:2rem;font-weight:800;color:#f59e0b;line-height:1;font-family:'Iceberg','Inter',sans-serif;">@ViewBag.MessageCount</div>
    <a href="/Admin/ContactMessages" style="display:inline-flex;align-items:center;gap:0.25rem;margin-top:0.75rem;font-size:0.78rem;color:#f59e0b;font-weight:600;">
      <svg width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      View All
    </a>
  </div>

</div>

<!-- Recent Activity -->
<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(340px,1fr));gap:1.25rem;">

  <div class="table-wrapper">
    <div style="padding:1rem 1.25rem;border-bottom:1px solid var(--color-border);display:flex;justify-content:space-between;align-items:center;">
      <h2 style="font-size:0.9rem;font-weight:700;color:var(--color-text);margin:0;">Recent Projects</h2>
      <a href="/Admin/Projects" style="font-size:0.78rem;color:var(--color-primary);">View All</a>
    </div>
    <table>
      <tbody>
        @foreach (var p in Model.RecentProjects)
        {
          <tr>
            <td style="font-weight:500;">@p.Title</td>
            <td style="color:var(--color-text-muted);font-size:0.78rem;white-space:nowrap;">@p.CreatedAt.ToString("MMM dd")</td>
            <td style="text-align:right;white-space:nowrap;"><a href="/Admin/Projects/Edit/@p.Id" class="btn btn-primary btn-sm">Edit</a></td>
          </tr>
        }
        @if (!Model.RecentProjects.Any())
        {
          <tr><td colspan="3" style="text-align:center;color:var(--color-text-muted);padding:1.5rem;">No projects yet</td></tr>
        }
      </tbody>
    </table>
  </div>

  <div class="table-wrapper">
    <div style="padding:1rem 1.25rem;border-bottom:1px solid var(--color-border);display:flex;justify-content:space-between;align-items:center;">
      <h2 style="font-size:0.9rem;font-weight:700;color:var(--color-text);margin:0;">Recent Blog Posts</h2>
      <a href="/Admin/BlogPosts" style="font-size:0.78rem;color:var(--color-primary);">View All</a>
    </div>
    <table>
      <tbody>
        @foreach (var b in Model.RecentBlogs)
        {
          <tr>
            <td style="font-weight:500;">@b.Title</td>
            <td style="color:var(--color-text-muted);font-size:0.78rem;white-space:nowrap;">@b.CreatedAt.ToString("MMM dd")</td>
            <td style="text-align:right;white-space:nowrap;"><a href="/Admin/BlogPosts/Edit/@b.Id" class="btn btn-primary btn-sm">Edit</a></td>
          </tr>
        }
        @if (!Model.RecentBlogs.Any())
        {
          <tr><td colspan="3" style="text-align:center;color:var(--color-text-muted);padding:1.5rem;">No posts yet</td></tr>
        }
      </tbody>
    </table>
  </div>

  <div class="table-wrapper">
    <div style="padding:1rem 1.25rem;border-bottom:1px solid var(--color-border);display:flex;justify-content:space-between;align-items:center;">
      <h2 style="font-size:0.9rem;font-weight:700;color:var(--color-text);margin:0;">Recent Messages</h2>
      <a href="/Admin/ContactMessages" style="font-size:0.78rem;color:var(--color-primary);">View All</a>
    </div>
    <table>
      <tbody>
        @foreach (var m in Model.RecentMessages)
        {
          <tr>
            <td>
              <div style="font-weight:500;font-size:0.875rem;">@m.Name</div>
              <div style="font-size:0.75rem;color:var(--color-text-muted);">@m.Email</div>
            </td>
            <td style="color:var(--color-text-muted);font-size:0.78rem;white-space:nowrap;">@m.CreatedAt.ToString("MMM dd")</td>
            <td style="text-align:right;white-space:nowrap;"><a href="/Admin/ContactMessages/Details/@m.Id" class="btn btn-ghost btn-sm">View</a></td>
          </tr>
        }
        @if (!Model.RecentMessages.Any())
        {
          <tr><td colspan="3" style="text-align:center;color:var(--color-text-muted);padding:1.5rem;">No messages yet</td></tr>
        }
      </tbody>
    </table>
  </div>

</div>
