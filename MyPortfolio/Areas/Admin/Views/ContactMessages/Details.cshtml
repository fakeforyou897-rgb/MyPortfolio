@{
  Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}
@model MyPortfolio.Models.Entities.ContactMessage

@{
  var senderJson = System.Text.Json.JsonSerializer.Serialize("message from " + Model.Name);
}

<div style="max-width:640px;">
  <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.75rem;">
    <a asp-action="Index" class="btn btn-ghost btn-sm">← Back</a>
    <h1 style="font-size:1.4rem;font-weight:800;color:var(--color-text);margin:0;">Message Details</h1>
  </div>

  <div class="card" style="padding:2rem;">
    <div style="display:grid;gap:1.25rem;">
      <div>
        <div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-text-muted);margin-bottom:0.3rem;">From</div>
        <div style="font-size:1rem;font-weight:700;color:var(--color-text);">@Model.Name</div>
        <div style="font-size:0.875rem;">
          <a href="mailto:@Model.Email" style="color:var(--color-primary);">@Model.Email</a>
        </div>
        @if (!string.IsNullOrEmpty(Model.Phone))
        {
          <div style="font-size:0.875rem;color:var(--color-text-muted);margin-top:0.25rem;">📞 @Model.Phone</div>
        }
      </div>

      <div class="divider"></div>

      @if (!string.IsNullOrEmpty(Model.Subject))
      {
        <div>
          <div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-text-muted);margin-bottom:0.3rem;">Subject</div>
          <div style="font-size:0.95rem;font-weight:600;color:var(--color-text);">@Model.Subject</div>
        </div>
      }

      <div>
        <div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-text-muted);margin-bottom:0.5rem;">Message</div>
        <div style="background:var(--color-surface-2);border:1px solid var(--color-border);border-radius:var(--radius-md);padding:1rem 1.25rem;font-size:0.9rem;line-height:1.75;color:var(--color-text);white-space:pre-wrap;">@Model.Message</div>
      </div>

      <div class="divider"></div>

      <div style="font-size:0.82rem;color:var(--color-text-muted);">
        Received: @Model.CreatedAt.ToString("MMMM dd, yyyy 'at' HH:mm")
      </div>
    </div>

    <div style="display:flex;gap:0.75rem;margin-top:1.5rem;flex-wrap:wrap;">
      <a href="mailto:@Model.Email?subject=Re: @(Model.Subject ?? "Your Message")" class="btn btn-primary" target="_blank">Reply via Email ↗</a>
      <form asp-action="DeleteConfirmed" method="post" style="display:inline;" onsubmit="event.preventDefault();confirmDelete(this,@Html.Raw(senderJson));return false;">
        <input type="hidden" name="id" value="@Model.Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
      </form>
      <a asp-action="Index" class="btn btn-ghost">Back to List</a>
    </div>
  </div>
</div>
