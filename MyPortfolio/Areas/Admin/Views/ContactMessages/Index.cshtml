@model IEnumerable<MyPortfolio.Models.Entities.ContactMessage>
@{
  Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.75rem;flex-wrap:wrap;gap:0.75rem;">
  <div>
    <h1 style="font-size:1.5rem;font-weight:800;color:var(--color-text);margin-bottom:0.2rem;">Contact Messages</h1>
    <p style="color:var(--color-text-muted);font-size:0.875rem;margin:0;">@Model.Count() message(s) received</p>
  </div>
</div>

<div class="table-wrapper">
  <table>
    <thead>
      <tr>
        <th>Sender</th>
        <th>Subject</th>
        <th>Received</th>
        <th style="text-align:right;">Actions</th>
      </tr>
    </thead>
    <tbody>
      @foreach (var msg in Model)
      {
        var senderJson = System.Text.Json.JsonSerializer.Serialize("message from " + msg.Name);
        <tr>
          <td>
            <div style="font-weight:600;color:var(--color-text);">@msg.Name</div>
            <div style="font-size:0.75rem;color:var(--color-text-muted);">@msg.Email</div>
          </td>
          <td style="font-size:0.875rem;color:var(--color-text-muted);max-width:260px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
            @(string.IsNullOrEmpty(msg.Subject) ? "(no subject)" : msg.Subject)
          </td>
          <td style="color:var(--color-text-muted);font-size:0.82rem;white-space:nowrap;">@msg.CreatedAt.ToString("MMM dd, yyyy")</td>
          <td style="text-align:right;white-space:nowrap;">
            <div style="display:flex;gap:0.4rem;justify-content:flex-end;">
              <a asp-action="Details" asp-route-id="@msg.Id" class="btn btn-ghost btn-sm">View</a>
              <form asp-action="DeleteConfirmed" method="post" style="display:inline;" onsubmit="event.preventDefault();confirmDelete(this,@Html.Raw(senderJson));return false;">
                <input type="hidden" name="id" value="@msg.Id" />
                <button type="submit" class="btn btn-danger btn-sm">Delete</button>
              </form>
            </div>
          </td>
        </tr>
      }
      @if (!Model.Any())
      {
        <tr>
          <td colspan="4" style="text-align:center;padding:3rem;color:var(--color-text-muted);">No messages received yet.</td>
        </tr>
      }
    </tbody>
  </table>
</div>
