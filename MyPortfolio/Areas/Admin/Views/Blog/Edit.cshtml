@{
  Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}
@model MyPortfolio.Models.Entities.BlogPost

<div style="max-width:760px;">
  <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.75rem;">
    <a href="@Url.Action("Index")" class="btn btn-ghost btn-sm">← Back</a>
    <h1 style="font-size:1.4rem;font-weight:800;color:var(--color-text);margin:0;">Edit Blog Post</h1>
  </div>

  <div class="card" style="padding:2rem;">
    <form asp-action="Edit" method="post">
      <input type="hidden" asp-for="Id" />
      <div asp-validation-summary="ModelOnly" class="form-alert form-alert-error" style="margin-bottom:1.25rem;"></div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;">
        <div class="form-group" style="grid-column:1/-1;">
          <label asp-for="Title" class="form-label">Title *</label>
          <input asp-for="Title" class="form-control" />
          <span asp-validation-for="Title" class="field-validation-error"></span>
        </div>

        <div class="form-group" style="grid-column:1/-1;">
          <label asp-for="Summary" class="form-label">Summary / Excerpt</label>
          <textarea asp-for="Summary" class="form-control" rows="2"></textarea>
        </div>

        <div class="form-group" style="grid-column:1/-1;">
          <label asp-for="Content" class="form-label">Content *</label>
          <textarea asp-for="Content" class="form-control" rows="10"></textarea>
          <span asp-validation-for="Content" class="field-validation-error"></span>
        </div>

        <div class="form-group">
          <label asp-for="Author" class="form-label">Author</label>
          <input asp-for="Author" class="form-control" />
        </div>

        <div class="form-group">
          <label asp-for="ReadingTimeMinutes" class="form-label">Reading Time (minutes)</label>
          <input asp-for="ReadingTimeMinutes" type="number" min="1" class="form-control" />
        </div>

        <div class="form-group">
          <label asp-for="ImageUrl" class="form-label">Card Image URL</label>
          <input asp-for="ImageUrl" class="form-control" />
        </div>

        <div class="form-group">
          <label asp-for="FeaturedImageUrl" class="form-label">Featured/Hero Image URL</label>
          <input asp-for="FeaturedImageUrl" class="form-control" />
        </div>

        <div class="form-group">
          <label asp-for="MetaTitle" class="form-label">Meta Title</label>
          <input asp-for="MetaTitle" class="form-control" />
        </div>

        <div class="form-group">
          <label asp-for="MetaKeywords" class="form-label">Meta Keywords</label>
          <input asp-for="MetaKeywords" class="form-control" />
        </div>

        <div class="form-group" style="grid-column:1/-1;">
          <label asp-for="MetaDescription" class="form-label">Meta Description</label>
          <textarea asp-for="MetaDescription" class="form-control" rows="2"></textarea>
        </div>
      </div>

      <div style="display:flex;gap:1rem;margin-top:0.5rem;flex-wrap:wrap;">
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;font-size:0.875rem;color:var(--color-text);">
          <input asp-for="IsPublished" type="checkbox" style="width:16px;height:16px;accent-color:var(--color-primary);" />
          Published
        </label>
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;font-size:0.875rem;color:var(--color-text);">
          <input asp-for="IsFeatured" type="checkbox" style="width:16px;height:16px;accent-color:var(--color-primary);" />
          Featured
        </label>
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;font-size:0.875rem;color:var(--color-text);">
          <input asp-for="AllowComments" type="checkbox" style="width:16px;height:16px;accent-color:var(--color-primary);" />
          Allow Comments
        </label>
      </div>

      <div style="display:flex;gap:0.75rem;margin-top:1.5rem;">
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a asp-action="Index" class="btn btn-ghost">Cancel</a>
      </div>
    </form>
  </div>
</div>

@section Scripts {
  <partial name="_ValidationScriptsPartial" />
}
