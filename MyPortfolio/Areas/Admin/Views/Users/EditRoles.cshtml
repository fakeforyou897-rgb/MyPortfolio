@model MyPortfolio.Models.ViewModels.Admin.EditRolesViewModel
@{
  Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div style="max-width:480px;">
  <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.75rem;">
    <a href="@Url.Action("Index","Users",new{area="Admin"})" class="btn btn-ghost btn-sm">← Back</a>
    <h1 style="font-size:1.4rem;font-weight:800;color:var(--color-text);margin:0;">Edit Roles</h1>
  </div>

  <div class="card" style="padding:2rem;">
    <div style="margin-bottom:1.25rem;">
      <div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-text-muted);margin-bottom:0.3rem;">User</div>
      <div style="font-weight:600;color:var(--color-text);">@Model.UserEmail</div>
    </div>

    <div class="divider"></div>

    <form asp-action="EditRoles" method="post" style="margin-top:1.25rem;">
      <input type="hidden" asp-for="UserId" />

      <div style="display:flex;flex-direction:column;gap:0.75rem;margin-bottom:1.5rem;">
        @foreach (var role in Model.Roles)
        {
          <label style="display:flex;align-items:center;gap:0.75rem;cursor:pointer;padding:0.75rem 1rem;border:1.5px solid var(--color-border);border-radius:var(--radius-md);transition:border-color 0.2s;">
            <input type="checkbox" asp-for="@role.Selected" style="width:18px;height:18px;accent-color:var(--color-primary);flex-shrink:0;" />
            <div>
              <div style="font-size:0.9rem;font-weight:600;color:var(--color-text);">@role.RoleName</div>
            </div>
          </label>
        }
      </div>

      <div style="display:flex;gap:0.75rem;">
        <button type="submit" class="btn btn-primary">Save Roles</button>
        <a href="@Url.Action("Index","Users",new{area="Admin"})" class="btn btn-ghost">Cancel</a>
      </div>
    </form>
  </div>
</div>
