@model Microsoft.AspNetCore.Identity.IdentityUser
@{
  Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div style="max-width:480px;">
  <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.75rem;">
    <a asp-action="Index" class="btn btn-ghost btn-sm">← Back</a>
    <h1 style="font-size:1.4rem;font-weight:800;color:var(--color-text);margin:0;">Delete User</h1>
  </div>

  <div class="card" style="padding:2rem;border-color:#fecaca;">
    <div class="modal-icon" style="margin:0 0 1.25rem;">
      <svg width="26" height="26" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
      </svg>
    </div>
    <h3 style="font-size:1rem;font-weight:700;color:var(--color-text);margin-bottom:0.5rem;">Are you sure?</h3>
    <p style="color:var(--color-text-muted);font-size:0.875rem;margin-bottom:0.25rem;">You are about to delete the user account:</p>
    <p style="font-weight:700;color:var(--color-text);font-size:0.95rem;margin-bottom:1.5rem;">@Model.Email</p>
    <p style="color:#dc2626;font-size:0.8rem;margin-bottom:1.5rem;">⚠️ This action cannot be undone.</p>

    <form asp-action="DeleteConfirmed" method="post">
      <input type="hidden" name="id" value="@Model.Id" />
      <div style="display:flex;gap:0.75rem;">
        <button type="submit" class="btn btn-danger">Yes, Delete</button>
        <a asp-action="Index" class="btn btn-ghost">Cancel</a>
      </div>
    </form>
  </div>
</div>
