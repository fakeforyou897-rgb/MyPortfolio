@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityUser>
@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager
@{
  Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.75rem;flex-wrap:wrap;gap:0.75rem;">
  <div>
    <h1 style="font-size:1.5rem;font-weight:800;color:var(--color-text);margin-bottom:0.2rem;">Users & Roles</h1>
    <p style="color:var(--color-text-muted);font-size:0.875rem;margin:0;">@Model.Count() registered user(s)</p>
  </div>
</div>

<div class="table-wrapper">
  <table>
    <thead>
      <tr>
        <th>Email</th>
        <th>Confirmed</th>
        <th>Role</th>
        <th style="text-align:right;">Actions</th>
      </tr>
    </thead>
    <tbody>
      @foreach (var user in Model)
      {
        var isAdmin = UserManager.IsInRoleAsync(user, "Admin").Result;
        var emailJson = System.Text.Json.JsonSerializer.Serialize(user.Email ?? "this user");
        <tr>
          <td>
            <div style="font-weight:600;color:var(--color-text);">@user.Email</div>
            <div style="font-size:0.72rem;color:var(--color-text-muted);margin-top:0.15rem;font-family:monospace;">@user.Id.Substring(0,8)…</div>
          </td>
          <td>
            @if (user.EmailConfirmed)
            {
              <span class="badge badge-success">✓ Confirmed</span>
            }
            else
            {
              <span class="badge badge-warning">Pending</span>
            }
          </td>
          <td>
            @if (isAdmin)
            {
              <span class="badge badge-primary">Admin</span>
            }
            else
            {
              <span class="badge badge-neutral">User</span>
            }
          </td>
          <td style="text-align:right;white-space:nowrap;">
            <div style="display:flex;gap:0.4rem;justify-content:flex-end;align-items:center;">
              <a asp-action="EditRoles" asp-route-id="@user.Id" class="btn btn-ghost btn-sm">Edit Roles</a>
              @if (!isAdmin)
              {
                <form asp-action="DeleteConfirmed" method="post" style="display:inline;" onsubmit="event.preventDefault();confirmDelete(this,@Html.Raw(emailJson));return false;">
                  <input type="hidden" name="id" value="@user.Id" />
                  <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                </form>
              }
              else
              {
                <span class="badge badge-neutral" style="cursor:not-allowed;" title="Admin accounts cannot be deleted">Protected</span>
              }
            </div>
          </td>
        </tr>
      }
    </tbody>
  </table>
</div>
