@model IEnumerable<MyPortfolio.Models.Entities.BlogPost>
@{
  ViewData["Title"] = "Blog";
}

<section class="section">
  <div class="container">

    <!-- Header -->
    <div style="margin-bottom:2.5rem;">
      <div class="badge badge-primary" style="margin-bottom:0.75rem;">Writing</div>
      <h1 class="section-title">Blog</h1>
      <p class="section-sub" style="margin-bottom:0;">Thoughts, tutorials, and deep dives on software development.</p>
    </div>

    @if (!Model.Any())
    {
      <!-- Skeleton when no posts -->
      <div class="grid-auto" id="blog-skeleton">
        @for (int i = 0; i < 3; i++)
        {
          <div class="skeleton-card">
            <div class="skeleton sk-img"></div>
            <div class="skeleton sk-title"></div>
            <div class="skeleton sk-line" style="width:50%;"></div>
            <div class="skeleton sk-line"></div>
            <div class="skeleton sk-line" style="width:80%;"></div>
          </div>
        }
      </div>
      <div style="text-align:center;padding:3rem 0;color:var(--color-text-muted);">
        No blog posts yet. Check back soon!
      </div>
    }
    else
    {
      <div class="grid-auto">
        @foreach (var post in Model)
        {
          <article class="blog-card">
            @if (!string.IsNullOrEmpty(post.FeaturedImageUrl))
            {
              <img src="@post.FeaturedImageUrl" alt="@post.Title" class="blog-card-img" loading="lazy" />
            }
            else
            {
              <div style="height:180px;background:linear-gradient(135deg,var(--color-primary-soft),var(--color-border));display:flex;align-items:center;justify-content:center;font-size:2.5rem;">📝</div>
            }
            <div class="blog-card-body">
              @if (post.IsFeatured)
              {
                <span class="badge badge-warning" style="margin-bottom:0.5rem;">⭐ Featured</span>
              }
              <h2 class="blog-card-title">
                <a href="@Url.Action("Details","Blog",new{id=post.Id})" style="color:var(--color-text);text-decoration:none;">
                  @post.Title
                </a>
              </h2>
              <div class="blog-card-meta">
                <span>✍️ @(!string.IsNullOrEmpty(post.Author) ? post.Author : "Admin")</span>
                &nbsp;·&nbsp;
                <span>📅 @(post.PublishedAt.HasValue ? post.PublishedAt.Value.ToString("MMM dd, yyyy") : "Draft")</span>
                @if (post.ReadingTimeMinutes > 0)
                {
                  <span>&nbsp;·&nbsp;⏱ @post.ReadingTimeMinutes min read</span>
                }
              </div>
              <p class="blog-card-desc" style="display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;">
                @(string.IsNullOrEmpty(post.Summary) ? (post.Content.Length > 140 ? post.Content.Substring(0,140)+"…" : post.Content) : post.Summary)
              </p>
              <div style="margin-top:1rem;">
                <a href="@Url.Action("Details","Blog",new{id=post.Id})" class="btn btn-primary btn-sm">Read More →</a>
              </div>
            </div>
          </article>
        }
      </div>
    }
  </div>
</section>
