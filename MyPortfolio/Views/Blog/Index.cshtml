@model IEnumerable<MyPortfolio.Models.Entities.BlogPost>
@{
  ViewData["Title"] = "Blog";
}

<section class="section">
  <div class="container">

    <div style="margin-bottom:2.5rem;">
      <div class="badge badge-primary" style="margin-bottom:0.75rem;" data-i18n="blog.badge">Writing</div>
      <h1 class="section-title" data-i18n="blog.title">Blog</h1>
      <p class="section-sub" style="margin-bottom:0;" data-i18n="blog.sub">Thoughts, tutorials, and deep dives on software development.</p>
    </div>

    @if (!Model.Any())
    {
      <div class="grid-auto" id="blog-skeleton">
        @for (int i = 0; i < 3; i++)
        {
          <div class="skeleton-card">
            <div class="skeleton sk-img"></div>
            <div class="skeleton sk-title"></div>
            <div class="skeleton sk-line" style="width:50%;"></div>
            <div class="skeleton sk-line"></div>
            <div class="skeleton sk-line" style="width:80%;"></div>
          </div>
        }
      </div>
      <div style="text-align:center;padding:3rem 0;color:var(--color-text-muted);">No blog posts yet. Check back soon!</div>
    }
    else
    {
      <div class="grid-auto">
        @foreach (var post in Model)
        {
          <article class="blog-card">
            @if (!string.IsNullOrEmpty(post.FeaturedImageUrl))
            {
              <img src="@post.FeaturedImageUrl" alt="@post.Title" class="blog-card-img" loading="lazy" />
            }
            else
            {
              <div style="height:180px;background:linear-gradient(135deg,var(--color-primary-soft),var(--color-border));display:flex;align-items:center;justify-content:center;">
                <svg width="40" height="40" fill="none" viewBox="0 0 24 24" stroke="var(--color-primary)" stroke-width="1.3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
              </div>
            }
            <div class="blog-card-body">
              @if (post.IsFeatured)
              {
                <span class="badge badge-warning" style="margin-bottom:0.5rem;">
                  <svg width="11" height="11" fill="currentColor" viewBox="0 0 24 24"><path d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
                  Featured
                </span>
              }
              <h2 class="blog-card-title">
                <a href="@Url.Action("Details","Blog",new{id=post.Id})" style="color:var(--color-text);text-decoration:none;">@post.Title</a>
              </h2>
              <div class="blog-card-meta">
                <span style="display:inline-flex;align-items:center;gap:0.25rem;">
                  <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
                  @(!string.IsNullOrEmpty(post.Author) ? post.Author : "Admin")
                </span>
                <span>·</span>
                <span style="display:inline-flex;align-items:center;gap:0.25rem;">
                  <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                  @(post.PublishedAt.HasValue ? post.PublishedAt.Value.ToString("MMM dd, yyyy") : "Draft")
                </span>
                @if (post.ReadingTimeMinutes > 0)
                {
                  <span>·</span>
                  <span style="display:inline-flex;align-items:center;gap:0.25rem;">
                    <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 7v5l3 3"/></svg>
                    @post.ReadingTimeMinutes min read
                  </span>
                }
              </div>
              <p class="blog-card-desc" style="display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;">
                @(string.IsNullOrEmpty(post.Summary) ? (post.Content.Length > 140 ? post.Content.Substring(0,140)+"…" : post.Content) : post.Summary)
              </p>
              <div style="margin-top:1rem;">
                <a href="@Url.Action("Details","Blog",new{id=post.Id})" class="btn btn-primary btn-sm">
                  <span data-i18n="blog.readMore">Read More</span>
                  <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </a>
              </div>
            </div>
          </article>
        }
      </div>
    }
  </div>
</section>
