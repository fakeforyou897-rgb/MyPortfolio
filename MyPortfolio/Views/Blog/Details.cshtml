@model MyPortfolio.Models.Entities.BlogPost
@{
  ViewData["Title"] = Model.Title;
}

<article class="section" style="max-width:780px;margin:0 auto;">
  <div class="container">

    <div style="margin-bottom:2rem;">
      <a href="@Url.Action("Index","Blog")" class="btn btn-ghost btn-sm">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        Back to Blog
      </a>
    </div>

    <header style="margin-bottom:2rem;">
      @if (Model.IsFeatured)
      {
        <span class="badge badge-warning" style="margin-bottom:0.75rem;display:inline-flex;">
          <svg width="11" height="11" fill="currentColor" viewBox="0 0 24 24"><path d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
          Featured
        </span>
      }
      <h1 style="font-size:clamp(1.75rem,4vw,2.75rem);font-weight:800;color:var(--color-text);line-height:1.2;margin-bottom:1rem;font-family:'Iceberg','Inter',sans-serif;">
        @Model.Title
      </h1>
      <div style="display:flex;flex-wrap:wrap;gap:1rem;align-items:center;font-size:0.82rem;color:var(--color-text-muted);margin-bottom:1.5rem;">
        <span style="display:inline-flex;align-items:center;gap:0.3rem;">
          <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
          @(!string.IsNullOrEmpty(Model.Author) ? Model.Author : "Admin")
        </span>
        <span>·</span>
        <span style="display:inline-flex;align-items:center;gap:0.3rem;">
          <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          @(Model.PublishedAt.HasValue ? Model.PublishedAt.Value.ToString("MMMM dd, yyyy") : "Not published")
        </span>
        @if (Model.ReadingTimeMinutes > 0)
        {
          <span>·</span>
          <span style="display:inline-flex;align-items:center;gap:0.3rem;">
            <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 7v5l3 3"/></svg>
            @Model.ReadingTimeMinutes min read
          </span>
        }
        @if (Model.ViewCount > 0)
        {
          <span>·</span>
          <span style="display:inline-flex;align-items:center;gap:0.3rem;">
            <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
            @Model.ViewCount views
          </span>
        }
      </div>
    </header>

    @if (!string.IsNullOrEmpty(Model.FeaturedImageUrl))
    {
      <div style="margin-bottom:2.5rem;border-radius:var(--radius-lg);overflow:hidden;border:1px solid var(--color-border);">
        <img src="@Model.FeaturedImageUrl" alt="@Model.Title" style="width:100%;height:360px;object-fit:cover;" loading="lazy" />
      </div>
    }
    else if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
      <div style="margin-bottom:2.5rem;border-radius:var(--radius-lg);overflow:hidden;border:1px solid var(--color-border);">
        <img src="@Model.ImageUrl" alt="@Model.Title" style="width:100%;max-height:360px;object-fit:cover;" loading="lazy" />
      </div>
    }

    @if (!string.IsNullOrEmpty(Model.Summary))
    {
      <div style="background:var(--color-primary-soft);border-radius:var(--radius-md);padding:1.1rem 1.4rem;margin-bottom:2rem;display:flex;gap:0.75rem;align-items:flex-start;">
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="var(--color-primary)" stroke-width="2" style="flex-shrink:0;margin-top:2px;"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <p style="color:var(--color-primary-text);font-style:italic;margin:0;font-size:0.95rem;">@Model.Summary</p>
      </div>
    }

    <div style="color:var(--color-text);line-height:1.8;font-size:1rem;">
      <div style="white-space:pre-wrap;word-break:break-word;">@Model.Content</div>
    </div>

    <div style="border-top:1px solid var(--color-border);margin-top:3rem;padding-top:1.5rem;display:flex;gap:1rem;flex-wrap:wrap;justify-content:space-between;align-items:center;">
      <a href="@Url.Action("Index","Blog")" class="btn btn-ghost">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        All Posts
      </a>
      <div style="display:flex;gap:0.75rem;align-items:center;">
        @if (Model.LikeCount > 0)
        {
          <span style="font-size:0.82rem;color:var(--color-text-muted);display:inline-flex;align-items:center;gap:0.3rem;">
            <svg width="13" height="13" fill="currentColor" viewBox="0 0 24 24" style="color:#ef4444;"><path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"/></svg>
            @Model.LikeCount likes
          </span>
        }
        @if (Model.ShareCount > 0)
        {
          <span style="font-size:0.82rem;color:var(--color-text-muted);display:inline-flex;align-items:center;gap:0.3rem;">
            <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>
            @Model.ShareCount shares
          </span>
        }
      </div>
    </div>

  </div>
</article>
