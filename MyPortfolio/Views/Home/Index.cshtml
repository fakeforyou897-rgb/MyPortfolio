@{
  ViewBag.Title = "Home";
}

<!-- ── Hero ── -->
<section class="hero" style="background:var(--color-bg);">
  <div class="container">
    <p class="badge badge-primary" style="margin-bottom:1.25rem;font-size:0.8rem;">
      <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
      <span data-i18n="home.available">Available for work</span>
    </p>
    <h1 class="hero-title">
      Hi, I'm <span style="color:var(--color-primary);">Your Name</span>
    </h1>
    <p class="hero-sub" data-i18n="home.heroSub">
      Full Stack Developer crafting modern web apps with ASP.NET Core, Tailwind CSS, and JavaScript.
    </p>
    <div class="hero-cta">
      <a href="/Projects" class="btn btn-primary btn-lg" data-i18n="home.viewWork">View My Work</a>
      <a href="/Contact" class="btn btn-ghost btn-lg" data-i18n="home.getInTouch">Get in Touch</a>
    </div>
  </div>
</section>

<!-- ── Stats Row ── -->
<section style="background:var(--color-surface);border-top:1px solid var(--color-border);border-bottom:1px solid var(--color-border);">
  <div class="container" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:0;padding-top:2rem;padding-bottom:2rem;">
    <div style="text-align:center;padding:0 1.5rem;border-inline-end:1px solid var(--color-border);">
      <div style="font-size:2rem;font-weight:800;color:var(--color-primary);font-family:'Iceberg',sans-serif;">3+</div>
      <div style="font-size:0.82rem;color:var(--color-text-muted);" data-i18n="home.yearsExp">Years Experience</div>
    </div>
    <div style="text-align:center;padding:0 1.5rem;border-inline-end:1px solid var(--color-border);">
      <div style="font-size:2rem;font-weight:800;color:var(--color-primary);font-family:'Iceberg',sans-serif;">20+</div>
      <div style="font-size:0.82rem;color:var(--color-text-muted);" data-i18n="home.projectsCount">Projects Completed</div>
    </div>
    <div style="text-align:center;padding:0 1.5rem;border-inline-end:1px solid var(--color-border);">
      <div style="font-size:2rem;font-weight:800;color:var(--color-primary);font-family:'Iceberg',sans-serif;">10+</div>
      <div style="font-size:0.82rem;color:var(--color-text-muted);" data-i18n="home.clients">Happy Clients</div>
    </div>
    <div style="text-align:center;padding:0 1.5rem;">
      <div style="font-size:2rem;font-weight:800;color:var(--color-primary);font-family:'Iceberg',sans-serif;">5.0</div>
      <div style="font-size:0.82rem;color:var(--color-text-muted);" data-i18n="home.rating">Average Rating</div>
    </div>
  </div>
</section>

<!-- ── About ── -->
<section class="section">
  <div class="container" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(340px,1fr));gap:3rem;align-items:center;">
    <div>
      <div class="badge badge-primary" style="margin-bottom:1rem;" data-i18n="home.aboutBadge">About Me</div>
      <h2 class="section-title" style="margin-bottom:1rem;" data-i18n="home.aboutTitle">A developer who loves clean code</h2>
      <p style="margin-bottom:1.25rem;">
        I'm a passionate full stack developer with expertise in building modern, performant web applications.
        I love turning complex problems into simple, beautiful, and intuitive solutions.
      </p>
      <p style="margin-bottom:1.75rem;">
        With a strong foundation in <strong style="color:var(--color-text);">ASP.NET Core</strong>,
        <strong style="color:var(--color-text);">EF Core</strong>, and
        <strong style="color:var(--color-text);">TailwindCSS</strong>, I build end-to-end solutions
        that are scalable and maintainable.
      </p>
      <a href="/Projects" class="btn btn-primary" data-i18n="home.seeProjects">See My Projects →</a>
    </div>

    <!-- Skill cards — no border-left -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
      <div class="card">
        <div class="skill-icon" style="background:rgba(37,99,235,0.12);color:var(--color-primary);">
          <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </div>
        <h4 style="font-size:0.9rem;font-weight:700;margin-bottom:0.3rem;" data-i18n="home.skill.backend">Backend</h4>
        <p style="font-size:0.8rem;margin:0;color:var(--color-text-muted);">ASP.NET Core · EF Core · SQL</p>
      </div>
      <div class="card">
        <div class="skill-icon" style="background:rgba(139,92,246,0.12);color:#8b5cf6;">
          <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 5h16M4 12h16M4 19h7"/>
          </svg>
        </div>
        <h4 style="font-size:0.9rem;font-weight:700;margin-bottom:0.3rem;" data-i18n="home.skill.frontend">Frontend</h4>
        <p style="font-size:0.8rem;margin:0;color:var(--color-text-muted);">Tailwind · React · TypeScript</p>
      </div>
      <div class="card">
        <div class="skill-icon" style="background:rgba(16,185,129,0.12);color:#10b981;">
          <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/>
          </svg>
        </div>
        <h4 style="font-size:0.9rem;font-weight:700;margin-bottom:0.3rem;" data-i18n="home.skill.devops">DevOps</h4>
        <p style="font-size:0.8rem;margin:0;color:var(--color-text-muted);">Docker · Azure · GitHub Actions</p>
      </div>
      <div class="card">
        <div class="skill-icon" style="background:rgba(245,158,11,0.12);color:#f59e0b;">
          <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <ellipse cx="12" cy="5" rx="9" ry="3"/><path stroke-linecap="round" d="M3 5v14a9 3 0 0018 0V5M3 12a9 3 0 0018 0"/>
          </svg>
        </div>
        <h4 style="font-size:0.9rem;font-weight:700;margin-bottom:0.3rem;" data-i18n="home.skill.db">Databases</h4>
        <p style="font-size:0.8rem;margin:0;color:var(--color-text-muted);">SQL Server · PostgreSQL · MongoDB</p>
      </div>
    </div>
  </div>
</section>

<!-- ── Featured Projects ── -->
<section class="section" style="background:var(--color-surface-2);">
  <div class="container">
    <div style="text-align:center;margin-bottom:2.5rem;">
      <div class="badge badge-primary" style="margin-bottom:0.75rem;" data-i18n="home.portfolioBadge">Portfolio</div>
      <h2 class="section-title" data-i18n="home.featuredTitle">Featured Projects</h2>
      <p class="section-sub" style="margin-bottom:0;" data-i18n="home.featuredSub">Highlights from my recent work</p>
    </div>
    <div class="grid-2">
      <div class="project-card">
        <div style="height:180px;background:linear-gradient(135deg,#1e3a5f,#2563eb);display:flex;align-items:center;justify-content:center;">
          <svg width="52" height="52" fill="none" viewBox="0 0 24 24" stroke="rgba(255,255,255,0.7)" stroke-width="1.2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
        </div>
        <div class="project-card-body">
          <div style="margin-bottom:0.5rem;"><span class="badge badge-success">Completed</span></div>
          <h3 class="project-card-title">E-Commerce Platform</h3>
          <p class="project-card-desc">Full-featured e-commerce with ASP.NET Core, React, and payment integration.</p>
        </div>
        <div class="project-card-footer">
          <a href="/Projects" class="btn btn-primary btn-sm">View Project
            <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
      <div class="project-card">
        <div style="height:180px;background:linear-gradient(135deg,#1a0533,#7c3aed);display:flex;align-items:center;justify-content:center;">
          <svg width="52" height="52" fill="none" viewBox="0 0 24 24" stroke="rgba(255,255,255,0.7)" stroke-width="1.2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
          </svg>
        </div>
        <div class="project-card-body">
          <div style="margin-bottom:0.5rem;"><span class="badge badge-success">Completed</span></div>
          <h3 class="project-card-title">Real-Time Chat App</h3>
          <p class="project-card-desc">Real-time chat with SignalR, Angular, and WebSocket support.</p>
        </div>
        <div class="project-card-footer">
          <a href="/Projects" class="btn btn-primary btn-sm">View Project
            <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
    <div style="text-align:center;margin-top:2rem;">
      <a href="/Projects" class="btn btn-secondary btn-lg" data-i18n="home.viewAll">View All Projects</a>
    </div>
  </div>
</section>

<!-- ── CTA ── -->
<section class="section" style="background:var(--color-primary);text-align:center;">
  <div class="container">
    <h2 style="font-size:2rem;font-weight:800;color:#fff;margin-bottom:0.75rem;font-family:'Iceberg',sans-serif;" data-i18n="home.ctaTitle">Let's Work Together</h2>
    <p style="color:rgba(255,255,255,0.82);max-width:500px;margin:0 auto 2rem;" data-i18n="home.ctaSub">
      Have a project in mind or want to collaborate? Get in touch and let's make it happen.
    </p>
    <a href="/Contact" class="btn btn-lg" style="background:#fff;color:var(--color-primary);font-weight:700;" data-i18n="home.ctaBtn">
      Contact Me →
    </a>
  </div>
</section>
