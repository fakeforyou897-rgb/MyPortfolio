@model MyPortfolio.Models.Entities.Project
@{
  ViewBag.Title = Model.Title;
}

<section class="section" style="max-width:860px;margin:0 auto;">
  <div class="container">

    <!-- Back -->
    <div style="margin-bottom:2rem;">
      <a href="@Url.Action("Index","Projects")" class="btn btn-ghost btn-sm">← All Projects</a>
    </div>

    <!-- Header -->
    <div style="margin-bottom:2rem;">
      @if (Model.IsFeatured)
      {
        <span class="badge badge-warning" style="margin-bottom:0.75rem;display:inline-block;">⭐ Featured</span>
      }
      @{
        var statusColor = Model.Status.ToString() == "Completed" ? "success" : "warning";
      }
      <span class="badge badge-@statusColor" style="margin-bottom:0.75rem;display:inline-block;margin-left:0.5rem;">@Model.Status</span>
      <h1 style="font-size:clamp(1.75rem,4vw,2.5rem);font-weight:800;color:var(--color-text);margin-bottom:0.75rem;">@Model.Title</h1>
      @if (!string.IsNullOrEmpty(Model.ShortDescription))
      {
        <p style="font-size:1.05rem;color:var(--color-text-muted);margin-bottom:0;">@Model.ShortDescription</p>
      }
    </div>

    <!-- Image -->
    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
      <div style="margin-bottom:2.5rem;border-radius:var(--radius-lg);overflow:hidden;border:1px solid var(--color-border);">
        <img src="@Model.ImageUrl" alt="@Model.Title" style="width:100%;max-height:420px;object-fit:cover;" loading="lazy" />
      </div>
    }

    <!-- Meta cards -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:1rem;margin-bottom:2.5rem;">
      @if (!string.IsNullOrEmpty(Model.ClientName))
      {
        <div class="card" style="padding:1rem;">
          <div style="font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-text-muted);margin-bottom:0.3rem;">Client</div>
          <div style="font-weight:600;color:var(--color-text);">@Model.ClientName</div>
        </div>
      }
      @if (Model.StartDate.HasValue)
      {
        <div class="card" style="padding:1rem;">
          <div style="font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-text-muted);margin-bottom:0.3rem;">Timeline</div>
          <div style="font-weight:600;color:var(--color-text);">
            @Model.StartDate.Value.ToString("MMM yyyy")
            @if (Model.EndDate.HasValue) { <span> → @Model.EndDate.Value.ToString("MMM yyyy")</span> }
            else { <span> → Present</span> }
          </div>
        </div>
      }
      @if (Model.Rating > 0)
      {
        <div class="card" style="padding:1rem;">
          <div style="font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-text-muted);margin-bottom:0.3rem;">Rating</div>
          <div style="font-weight:600;color:var(--color-text);">
            @for (int i = 1; i <= 5; i++) { <span style="color:@(i <= Model.Rating ? "#f59e0b" : "var(--color-border)");">★</span> }
          </div>
        </div>
      }
    </div>

    <!-- Description -->
    <div class="card" style="margin-bottom:2rem;">
      <h2 style="font-size:1.1rem;font-weight:700;margin-bottom:1rem;color:var(--color-text);">About This Project</h2>
      <p style="line-height:1.8;color:var(--color-text-muted);margin:0;">@Model.Description</p>
    </div>

    <!-- Technologies -->
    @if (!string.IsNullOrEmpty(Model.Technologies))
    {
      <div style="margin-bottom:2rem;">
        <h3 style="font-size:0.875rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-text-muted);margin-bottom:0.75rem;">Technologies Used</h3>
        <div style="display:flex;flex-wrap:wrap;gap:0.5rem;">
          @foreach (var tech in Model.Technologies.Split(','))
          {
            <span class="badge badge-primary" style="font-size:0.8rem;padding:0.3rem 0.75rem;">@tech.Trim()</span>
          }
        </div>
      </div>
    }

    <!-- Links -->
    <div style="display:flex;gap:0.75rem;flex-wrap:wrap;margin-bottom:3rem;">
      @if (!string.IsNullOrEmpty(Model.GitHubUrl))
      {
        <a href="@Model.GitHubUrl" target="_blank" rel="noopener" class="btn btn-secondary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub Repo
        </a>
      }
      @if (!string.IsNullOrEmpty(Model.LiveDemoUrl))
      {
        <a href="@Model.LiveDemoUrl" target="_blank" rel="noopener" class="btn btn-primary">
          <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          Live Demo ↗
        </a>
      }
    </div>

    <div style="border-top:1px solid var(--color-border);padding-top:1.5rem;">
      <a href="@Url.Action("Index","Projects")" class="btn btn-ghost">← Back to Projects</a>
    </div>
  </div>
</section>
