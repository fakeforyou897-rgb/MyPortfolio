@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager

@{
  string ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
}

<nav id="main-navbar" class="navbar">
  <div class="container" style="display:flex;align-items:center;justify-content:space-between;height:68px;">

    <!-- Logo -->
    <a href="/" style="font-size:1.25rem;font-weight:800;color:var(--color-primary);letter-spacing:-0.02em;text-decoration:none;">
      MyPortfolio
    </a>

    <!-- Desktop Links -->
    <ul style="display:flex;align-items:center;gap:0.25rem;list-style:none;margin:0;padding:0;" class="desktop-nav">
      <li><a class="nav-link" data-href="/" href="/">Home</a></li>
      <li><a class="nav-link" data-href="/Projects" href="/Projects">Projects</a></li>
      <li><a class="nav-link" data-href="/Blog" href="/Blog">Blog</a></li>
      <li><a class="nav-link" data-href="/Contact" href="/Contact">Contact</a></li>
      @if (SignInManager.IsSignedIn(User) && User.IsInRole("Admin"))
      {
        <li><a class="nav-link" data-href="/Admin" href="/Admin" style="color:var(--color-primary);font-weight:600;">Admin</a></li>
      }
    </ul>

    <!-- Right Controls -->
    <div style="display:flex;align-items:center;gap:0.5rem;">
      <!-- Theme Toggle -->
      <button id="theme-toggle" class="theme-btn" title="Toggle theme" aria-label="Toggle theme">
        <!-- Sun (shown in dark mode) -->
        <svg id="icon-sun" class="hidden" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5"/><path stroke-linecap="round" d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
        </svg>
        <!-- Moon (shown in light mode) -->
        <svg id="icon-moon" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
        </svg>
      </button>

      <!-- Mobile Hamburger -->
      <button id="mobile-menu-btn" class="theme-btn desktop-hide" aria-label="Open menu" style="display:none;">
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden" style="border-top:1px solid var(--color-border);background:var(--color-surface);">
    <ul style="list-style:none;margin:0;padding:0.75rem 1.5rem 1rem;display:flex;flex-direction:column;gap:0.25rem;">
      <li><a class="nav-link" href="/">Home</a></li>
      <li><a class="nav-link" href="/Projects">Projects</a></li>
      <li><a class="nav-link" href="/Blog">Blog</a></li>
      <li><a class="nav-link" href="/Contact">Contact</a></li>
      @if (SignInManager.IsSignedIn(User) && User.IsInRole("Admin"))
      {
        <li><a class="nav-link" href="/Admin" style="color:var(--color-primary);font-weight:600;">Admin</a></li>
      }
    </ul>
  </div>
</nav>

<style>
  @@media (max-width: 768px) {
    .desktop-nav { display: none !important; }
    #mobile-menu-btn { display: flex !important; }
    .nav-link { display: block; padding: 0.5rem 0.75rem; }
  }
</style>
