@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager

@{
  string ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
}

<nav id="main-navbar" class="navbar">
  <div class="container navbar-inner">

    <!-- Logo -->
    <a href="/" class="navbar-logo" data-i18n-attr="href:/">
      <span class="logo-text">My</span><span class="logo-accent">Portfolio</span>
    </a>

    <!-- Desktop Nav Links -->
    <ul class="desktop-nav">
      <li><a class="nav-link" data-href="/" href="/" data-i18n="nav.home">Home</a></li>
      <li><a class="nav-link" data-href="/Projects" href="/Projects" data-i18n="nav.projects">Projects</a></li>
      <li><a class="nav-link" data-href="/Blog" href="/Blog" data-i18n="nav.blog">Blog</a></li>
      <li><a class="nav-link" data-href="/Contact" href="/Contact" data-i18n="nav.contact">Contact</a></li>
      @if (SignInManager.IsSignedIn(User) && User.IsInRole("Admin"))
      {
        <li><a class="nav-link" data-href="/Admin" href="/Admin" style="color:var(--color-primary);font-weight:700;" data-i18n="nav.admin">Admin</a></li>
      }
    </ul>

    <!-- Right Controls -->
    <div class="navbar-controls">

      <!-- Language Toggle -->
      <button id="lang-toggle" class="icon-btn" title="Switch language / تغيير اللغة" aria-label="Toggle language">
        <svg width="17" height="17" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/>
        </svg>
        <span id="lang-label" style="font-size:0.78rem;font-weight:700;letter-spacing:0.03em;">AR</span>
      </button>

      <!-- Theme Toggle -->
      <button id="theme-toggle" class="icon-btn" title="Toggle theme" aria-label="Toggle theme">
        <svg id="icon-sun" class="hidden" width="17" height="17" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5"/><path stroke-linecap="round" d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
        </svg>
        <svg id="icon-moon" width="17" height="17" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
        </svg>
      </button>

      <!-- Mobile Hamburger -->
      <button id="mobile-menu-btn" class="icon-btn mobile-only" aria-label="Open menu">
        <svg id="hamburger-icon" width="17" height="17" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden mobile-menu-panel">
    <ul>
      <li><a class="nav-link" href="/" data-i18n="nav.home">Home</a></li>
      <li><a class="nav-link" href="/Projects" data-i18n="nav.projects">Projects</a></li>
      <li><a class="nav-link" href="/Blog" data-i18n="nav.blog">Blog</a></li>
      <li><a class="nav-link" href="/Contact" data-i18n="nav.contact">Contact</a></li>
      @if (SignInManager.IsSignedIn(User) && User.IsInRole("Admin"))
      {
        <li><a class="nav-link" href="/Admin" style="color:var(--color-primary);font-weight:700;" data-i18n="nav.admin">Admin</a></li>
      }
    </ul>
  </div>
</nav>

<style>
  .navbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }
  .navbar-logo {
    font-family: 'Iceberg', sans-serif;
    font-size: 1.35rem;
    text-decoration: none;
    letter-spacing: 0.02em;
    flex-shrink: 0;
  }
  .logo-text { color: var(--color-text); }
  .logo-accent { color: var(--color-primary); }
  .navbar-controls {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex-shrink: 0;
  }
  .icon-btn {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.45rem 0.6rem;
    border-radius: var(--radius-md);
    background: transparent;
    border: 1.5px solid var(--color-border);
    color: var(--color-text-muted);
    cursor: pointer;
    transition: var(--transition);
    font-family: inherit;
  }
  .icon-btn:hover {
    background: var(--color-primary-soft);
    color: var(--color-primary);
    border-color: var(--color-primary);
  }
  .desktop-nav {
    display: flex;
    align-items: center;
    gap: 0.15rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .mobile-menu-panel {
    border-top: 1px solid var(--color-border);
    background: var(--color-surface);
  }
  .mobile-menu-panel ul {
    list-style: none;
    margin: 0;
    padding: 0.75rem 1.5rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .mobile-menu-panel .nav-link { display: block; padding: 0.55rem 0.75rem; border-radius: var(--radius-md); }
  .mobile-only { display: none !important; }
  @@media (max-width: 768px) {
    .desktop-nav { display: none !important; }
    .mobile-only { display: flex !important; }
  }
</style>
