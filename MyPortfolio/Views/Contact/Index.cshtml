@model MyPortfolio.Models.ViewModels.ContactMessageViewModel
@{
  ViewData["Title"] = "Contact";
}

<section class="section">
  <div class="container" style="max-width:900px;">

    <div style="text-align:center;margin-bottom:3rem;">
      <div class="badge badge-primary" style="margin-bottom:0.75rem;" data-i18n="contact.badge">Get In Touch</div>
      <h1 class="section-title" data-i18n="contact.title">Contact Me</h1>
      <p class="section-sub" style="margin-bottom:0;" data-i18n="contact.sub">Have a project or idea? I'd love to hear from you.</p>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:2.5rem;align-items:start;">

      <!-- Contact Info -->
      <div>
        <h3 style="font-size:1.05rem;font-weight:700;margin-bottom:1.25rem;color:var(--color-text);" data-i18n="contact.connect">Let's connect</h3>
        <div style="display:flex;flex-direction:column;gap:1rem;">

          <div class="card" style="display:flex;align-items:center;gap:0.875rem;padding:1rem 1.25rem;">
            <div style="width:40px;height:40px;border-radius:var(--radius-md);background:var(--color-primary-soft);display:flex;align-items:center;justify-content:center;flex-shrink:0;color:var(--color-primary);">
              <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <div>
              <div style="font-size:0.72rem;font-weight:600;color:var(--color-text-muted);text-transform:uppercase;letter-spacing:0.05em;" data-i18n="contact.email">Email</div>
              <div style="font-size:0.875rem;font-weight:600;color:var(--color-text);">hello@yourportfolio.dev</div>
            </div>
          </div>

          <div class="card" style="display:flex;align-items:center;gap:0.875rem;padding:1rem 1.25rem;">
            <div style="width:40px;height:40px;border-radius:var(--radius-md);background:var(--color-primary-soft);display:flex;align-items:center;justify-content:center;flex-shrink:0;color:var(--color-primary);">
              <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <div>
              <div style="font-size:0.72rem;font-weight:600;color:var(--color-text-muted);text-transform:uppercase;letter-spacing:0.05em;" data-i18n="contact.location">Location</div>
              <div style="font-size:0.875rem;font-weight:600;color:var(--color-text);" data-i18n="contact.locationVal">Available Worldwide (Remote)</div>
            </div>
          </div>

          <div class="card" style="display:flex;align-items:center;gap:0.875rem;padding:1rem 1.25rem;">
            <div style="width:40px;height:40px;border-radius:var(--radius-md);background:var(--color-primary-soft);display:flex;align-items:center;justify-content:center;flex-shrink:0;color:var(--color-primary);">
              <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 7v5l3 3"/></svg>
            </div>
            <div>
              <div style="font-size:0.72rem;font-weight:600;color:var(--color-text-muted);text-transform:uppercase;letter-spacing:0.05em;" data-i18n="contact.responseTime">Response Time</div>
              <div style="font-size:0.875rem;font-weight:600;color:var(--color-text);" data-i18n="contact.responseVal">Usually within 24 hours</div>
            </div>
          </div>

        </div>
      </div>

      <!-- Contact Form -->
      <div class="card" style="padding:2rem;">
        @if (ViewBag.Success != null)
        {
          <div class="form-alert form-alert-success" style="margin-bottom:1.25rem;">
            <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="flex-shrink:0;"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            @ViewBag.Success
          </div>
        }

        <form asp-action="Index" method="post" id="contact-form">
          @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
          {
            <div class="form-alert form-alert-error" style="margin-bottom:1.25rem;">
              <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="flex-shrink:0;"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <div>Please fix the errors below and try again.</div>
            </div>
          }

          <div class="form-group">
            <label asp-for="Name" class="form-label">Full Name *</label>
            <input asp-for="Name" class="form-control" placeholder="John Smith" />
            <span asp-validation-for="Name" class="field-validation-error"></span>
          </div>

          <div class="form-group">
            <label asp-for="Email" class="form-label">Email Address *</label>
            <input asp-for="Email" type="email" class="form-control" placeholder="john@example.com" />
            <span asp-validation-for="Email" class="field-validation-error"></span>
          </div>

          <div class="form-group">
            <label asp-for="Phone" class="form-label">Phone <span style="color:var(--color-text-muted);font-weight:400;">(Optional)</span></label>
            <input asp-for="Phone" class="form-control" placeholder="+1 (555) 000-0000" />
            <span asp-validation-for="Phone" class="field-validation-error"></span>
          </div>

          <div class="form-group">
            <label asp-for="Subject" class="form-label">Subject *</label>
            <input asp-for="Subject" class="form-control" placeholder="Project inquiry, collaboration…" />
            <span asp-validation-for="Subject" class="field-validation-error"></span>
          </div>

          <div class="form-group">
            <label asp-for="Message" class="form-label">Message *</label>
            <textarea asp-for="Message" class="form-control" rows="5" placeholder="Tell me about your project or idea…"></textarea>
            <span asp-validation-for="Message" class="field-validation-error"></span>
          </div>

          <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:0.75rem;">
            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
            <span data-i18n="contact.send">Send Message →</span>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

@section Scripts {
  <partial name="_ValidationScriptsPartial" />
  @if (ViewBag.Success != null)
  {
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        window.showToast("success", "Message Sent!", "@ViewBag.Success");
      });
    </script>
  }
}
